{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@ui/*": ["./src/packages/ui/*"],
      "@db/*": ["./src/packages/db/*"],
      "@auth/*": ["./src/packages/auth/*"],
      "@utils/*": ["./src/packages/utils/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@providers/*": ["./src/providers/*"],
      "@alloggiati/*": ["./src/packages/alloggiati/*"],
      "@istat/*": ["./src/packages/istat/*"],
      "@ai/*": ["./src/packages/ai/*"],
      "@ical/*": ["./src/packages/ical/*"],
      "@export/*": ["./src/packages/export/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "Figma"]
}
